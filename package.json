{
  "name": "nvkm-ecommerce",
  "version": "1.0.0",
  "description": "NVKM GROUP E-Commerce - MERN Stack with Supabase",
  "main": "server/index.js",
  "scripts": {
    "dev": "npx concurrently \"npm run server\" \"npm run client\"",
    "server": "npx nodemon server/index.js",
    "client": "npm run dev --prefix client",
    "seed": "node server/seed.js",
    "install-all": "npm install && npm install --prefix client"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.3"
  },
  "keywords": ["ecommerce", "mern", "nvkm", "supabase"],
  "author": "NVKM GROUP",
  "license": "ISC"
}
